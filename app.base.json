{
  "expo": {
    "name": "Vyra Fitness",
    "slug": "vyra-fitness",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vyrafitness",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B1726"
      },
      "package": "com.vyrafitness.app",
      "versionCode": 2,
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.health.READ_STEPS",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.vyrafitness.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Vyra necesita tu camara para escanear codigos y analizar comidas cuando tu lo eliges.",
        "NSMicrophoneUsageDescription": "Vyra necesita tu microfono para registrar comidas por voz cuando tu lo activas.",
        "NSPhotoLibraryUsageDescription": "Vyra necesita acceso a tus fotos para analizar comidas desde tu galeria.",
        "NSPhotoLibraryAddUsageDescription": "Vyra necesita guardar y compartir exportaciones o capturas generadas por ti.",
        "NSFaceIDUsageDescription": "Vyra puede usar biometria para proteger tu reingreso y tus datos sensibles.",
        "NSLocationWhenInUseUsageDescription": "Vyra necesita tu ubicacion para registrar rutas de caminata.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Vyra necesita tu ubicacion para registrar rutas incluso en segundo plano.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "react-native-health-connect",
      "@react-native-community/datetimepicker",
      [
        "expo-av",
        {
          "microphonePermission": "Vyra necesita tu microfono para registrar comidas por voz cuando tu lo activas."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Vyra necesita la camara para escanear codigos de barras y analizar fotos de comidas."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Vyra necesita acceso a tus fotos para analizar comidas desde la galeria."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0B1726"
        }
      ],
      "expo-secure-store",
      "./plugins/withAndroidKotlinJvmTarget",
      [
        "@bittingz/expo-widgets",
        {
          "android": {
            "src": "./widgets/android",
            "distPlaceholder": "com.vyrafitness.app",
            "widgets": [
              {
                "name": "VyraCompactWidgetProvider",
                "resourceName": "@xml/vyra_widget_compact_info"
              },
              {
                "name": "VyraExpandedWidgetProvider",
                "resourceName": "@xml/vyra_widget_expanded_info"
              }
            ]
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "vyra-fitness",
          "project": "vyra-fitness-android",
          "uploadSourceMaps": false
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "legalUrls": {
        "privacyPolicy": "https://raw.githubusercontent.com/natanaelprogimo-afk/vyra-fitness/master/legal/PRIVACY_POLICY.md",
        "termsOfService": "https://raw.githubusercontent.com/natanaelprogimo-afk/vyra-fitness/master/legal/TERMS_OF_SERVICE.md"
      },
      "sleepSoundsBaseUrl": "",
      "exerciseMediaBaseUrl": "https://kvnagjljrezvpuflrpqm.supabase.co/storage/v1/object/public/exercise-media",
      "apis": {
        "supabase": "https://kvnagjljrezvpuflrpqm.supabase.co",
        "backend": "https://vyra-backend-5fd9.onrender.com"
      },
      "eas": {
        "projectId": "d417aa09-2b05-455a-8d68-fb88c2317451"
      }
    }
  }
}

