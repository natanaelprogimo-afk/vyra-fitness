// Frontend `.env.example` — placeholders only. NEVER commit real secrets.
# Replace values locally in a file named `.env` (do NOT commit `.env`).

# Supabase (public)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key_here

# Backend API
EXPO_PUBLIC_API_URL=https://vyra-backend.example.com

# Sentry (public DSN placeholder)
EXPO_PUBLIC_SENTRY_DSN=https://your_public_sentry_dsn

# Unity Ads (public game id)
EXPO_PUBLIC_UNITY_GAME_ID=6050750
EXPO_PUBLIC_UNITY_REWARDED_AD=your_rewarded_ad_unit
EXPO_PUBLIC_UNITY_INTERSTITIAL_AD=your_interstitial_ad_unit
EXPO_PUBLIC_UNITY_BANNER_AD=your_banner_ad_unit

# PostHog (public key)
EXPO_PUBLIC_POSTHOG_KEY=your_posthog_key

# PayPal (public client id only)
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# NOTE: Secret keys (service role, PayPal client secret, GROQ secret) MUST live only on the BACKEND and in deployment secrets.
