{
  "expo": {
    "name": "Vyra Fitness",
    "slug": "vyra-fitness",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vyrafitness",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A1E"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "package": "com.vyrafitness.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Vyra necesita la cámara para escanear códigos de barras y analizar fotos de comidas."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#7C3AED"
        }
      ],
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "organization": "vyra-fitness",
          "project": "vyra-fitness-android",
          "uploadSourceMaps": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "legalUrls": {
        "privacyPolicy": "https://github.com/natan.../vyra-fitness/legal/PRIVACY_POLICY.md",
        "termsOfService": "https://github.com/natan.../vyra-fitness/legal/TERMS_OF_SERVICE.md"
      },
      "apis": {
        "supabase": "https://fkwisfxwztlkrlcvuwdv.supabase.co",
        "backend": "https://vyra-backend-5fd9.onrender.com",
        
      },
      "eas": {
        "projectId": "d417aa09-2b05-455a-8d68-fb88c2317451"
      }
    }
  }
}